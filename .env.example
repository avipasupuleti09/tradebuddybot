FYERS_CLIENT_ID=YOUR_CLIENT_ID
FYERS_SECRET_KEY=YOUR_SECRET_KEY
FYERS_REDIRECT_URI=http://localhost:5000/api/auth/callback
FYERS_USER_ID=YOUR_USER_ID
FYERS_TOTP_KEY=YOUR_TOTP_KEY
FYERS_PIN=YOUR_PIN
FYERS_TOKEN_FILE=.tokens/fyers_token.json
FYERS_ORDER_STATIC_IP=
FYERS_ENFORCE_STATIC_IP_CHECK=true
PUBLIC_IP_CHECK_URL=https://api.ipify.org
FYERS_PAPER_TRADE_MODE=true
FRONTEND_URL=http://localhost:5100

# Hosted deployment options
PYTHON_AUTOSTART=true
# PYTHON_API_BASE=https://your-python-api.example
# SKIP_PYTHON_BOOTSTRAP=true
# PYTHON_CMD=python3# FYERS app credentials
FYERS_CLIENT_ID=YOUR_APP_ID-100
FYERS_SECRET_KEY=YOUR_SECRET_KEY
FYERS_REDIRECT_URI=http://localhost:5000/api/auth/callback

# FYERS user credentials used for backend-only login automation
FYERS_USER_ID=YOUR_FYERS_USER_ID
FYERS_TOTP_KEY=YOUR_TOTP_SECRET
FYERS_PIN=YOUR_4_DIGIT_PIN

# Local token storage path
FYERS_TOKEN_FILE=.tokens/fyers_token.json

# Static IP configuration for SEBI-compliant order placement
# Put the same public static IP that is whitelisted in FYERS
FYERS_ORDER_STATIC_IP=

# Keep this true to block order placement when current public IP does not match
FYERS_ENFORCE_STATIC_IP_CHECK=true

# Public IP discovery endpoint used before placing orders
PUBLIC_IP_CHECK_URL=https://api.ipify.org

# Safety switch: when true, place-order simulates and does not send live orders
FYERS_PAPER_TRADE_MODE=true

# Frontend URL where backend redirects after manual FYERS login callback
FRONTEND_URL=http://localhost:5100

# ── NSE Scanner settings ─────────────────────────────────────────────────
SCANNER_PORT=8001
FLASK_API_BASE=http://localhost:5000
WATCHLIST_SYMBOLS=RELIANCE,TCS,INFY,HDFCBANK,ICICIBANK
DATA_SOURCE_MODE=env
BOOTSTRAP_SCAN_ON_REQUEST=true
PERSIST_WORKBOOK=false
